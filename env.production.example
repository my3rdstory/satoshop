# 운영 환경 설정 (.env.production)
# Render 또는 다른 운영 서버에서 사용할 수 있도록 현재 코드 기준 변수 집합을 정리한 예시입니다.

# -----------------------------------------------------------------------------
# Django 기본 설정
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-production-secret-key
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# 데이터베이스 설정
# Render Postgres 사용 시 보통 Render가 값을 주입합니다.
# -----------------------------------------------------------------------------
DB_NAME=replace-with-production-db-name
DB_USER=replace-with-production-db-user
DB_PASSWORD=replace-with-production-db-password
DB_HOST=replace-with-production-db-host
DB_PORT=5432

# -----------------------------------------------------------------------------
# 도메인 / 인증
# -----------------------------------------------------------------------------
LNURL_AUTH_ROOT_DOMAIN=yourdomain.com
# LNURL_DOMAIN=yourdomain.com
LNURL_AUTH_K1_TIMEOUT=3600
MINIHOME_LIST_DOMAIN=

# -----------------------------------------------------------------------------
# Blink 결제 / 스토어 API 암호화
# -----------------------------------------------------------------------------
BLINK_API_KEY=replace-with-production-blink-api-key
BLINK_WALLET_ID=replace-with-production-blink-wallet-id
BLINK_WEBHOOK_SECRET=replace-with-production-blink-webhook-secret
BLINK_ENCRYPTION_KEY=replace-with-production-32-byte-encryption-key

# -----------------------------------------------------------------------------
# Expert 기능
# 미설정 시 EXPERT_* 는 기본적으로 BLINK_* 값으로 폴백합니다.
# -----------------------------------------------------------------------------
EXPERT_BLINK_API_KEY=
EXPERT_BLINK_WALLET_ID=
EXPERT_BLINK_MEMO_PREFIX=SatoShop Expert 계약 결제
EXPERT_SIGNER_CERT_PATH=
EXPERT_SIGNER_CERT_BASE64=
EXPERT_SIGNER_CERT_PASSWORD=
# EXPERT_FONT_DIR=/app/expert/static/expert/fonts
# EXPERT_SIGNATURE_MEDIA_FALLBACK=False

# -----------------------------------------------------------------------------
# S3 호환 오브젝트 스토리지
# -----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=replace-with-production-access-key
S3_SECRET_ACCESS_KEY=replace-with-production-secret-key
S3_BUCKET_NAME=replace-with-production-bucket
S3_ENDPOINT_URL=https://replace-with-production-endpoint
S3_REGION_NAME=kr-standard
S3_USE_SSL=True
S3_FILE_OVERWRITE=False
S3_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# 미디어 핫링크 보호
# -----------------------------------------------------------------------------
HOTLINK_PROTECTION_ENABLED=True
HOTLINK_ALLOWED_DOMAINS=yourdomain.com,www.yourdomain.com

# -----------------------------------------------------------------------------
# 메일 발송
# -----------------------------------------------------------------------------
EMAIL_HOST_USER=replace-with-production-email@gmail.com
EMAIL_HOST_PASSWORD=replace-with-production-app-password
DEFAULT_FROM_EMAIL=replace-with-production-email@gmail.com

# -----------------------------------------------------------------------------
# 환율 업데이트 웹훅 / 외부 크론
# -----------------------------------------------------------------------------
WEBHOOK_TOKEN=replace-with-production-webhook-token

# 외부 크론 스크립트를 같은 값 세트로 관리할 때만 사용
# WEBHOOK_URLS=https://yourdomain.com/webhook/update-exchange-rate/

# -----------------------------------------------------------------------------
# 실시간 / 채널 레이어 확장
# 현재 코드에는 Redis 분기가 있지만 channels-redis 의존성은 별도 추가가 필요합니다.
# -----------------------------------------------------------------------------
CHANNEL_REDIS_URL=
# REDIS_URL=

# -----------------------------------------------------------------------------
# Render / Docker 런타임
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true
RUN_COLLECTSTATIC=true
RUN_SYSTEM_CHECK=false
PORT=8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 과거 빌드 스크립트(build.sh) 호환용 참고값
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-production-admin-password
