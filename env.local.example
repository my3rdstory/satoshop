# 로컬 개발 환경 설정 (.env.local)
# 이 파일을 `.env.local`로 복사해 사용합니다.
# 현재 코드와 운영 보조 스크립트가 참조하는 환경 변수를 한 번에 정리한 완전판 예시입니다.

# -----------------------------------------------------------------------------
# Django 기본 설정
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-local-secret-key
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1
# 프런트 개발 서버나 ngrok를 붙일 때만 추가
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# 데이터베이스 설정
# 현재 docker-compose.yml 기준 PostgreSQL은 127.0.0.1:5434 로 열립니다.
# -----------------------------------------------------------------------------
DB_NAME=satoshop-main
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=5434

# 참고: 아래 값은 앱이 직접 읽지는 않지만 docker-compose 초기값과 맞춰두면 관리가 쉽습니다.
# POSTGRES_DB=satoshop-main
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password

# -----------------------------------------------------------------------------
# 도메인 / 로컬 접근 / 인증
# -----------------------------------------------------------------------------
# ngrok를 쓰지 않으면 localhost:8011 기준으로 두면 됩니다.
LNURL_AUTH_ROOT_DOMAIN=localhost:8011
# 기존 호환성용 별칭. 보통 비워둬도 됩니다.
# LNURL_DOMAIN=localhost:8011
LNURL_AUTH_K1_TIMEOUT=3600

# ngrok 사용 시만 지정
# NGROK_DOMAIN=your-ngrok-subdomain.ngrok-free.app

# Minihome 목록 전용 도메인을 로컬에서 별도로 붙일 때만 사용
# MINIHOME_LIST_DOMAIN=minihome.localtest.me

# -----------------------------------------------------------------------------
# Blink 결제 / 스토어 API 암호화
# -----------------------------------------------------------------------------
BLINK_API_KEY=replace-with-local-blink-api-key
BLINK_WALLET_ID=replace-with-local-blink-wallet-id

# Blink webhook 서명 검증을 쓸 때 필요
# 미설정 시 webhook은 서명 검증 없이 JSON만 파싱합니다.
BLINK_WEBHOOK_SECRET=

# 스토어에 저장하는 Blink 자격정보 암호화 키
# 미설정 시 DEBUG 환경에서는 개발용 고정 키로 동작하므로, 실제 검증 시 넣는 편이 안전합니다.
BLINK_ENCRYPTION_KEY=replace-with-32-byte-encryption-key

# -----------------------------------------------------------------------------
# Expert 기능
# -----------------------------------------------------------------------------
# 미설정 시 EXPERT_* 는 기본적으로 BLINK_* 값으로 폴백합니다.
EXPERT_BLINK_API_KEY=
EXPERT_BLINK_WALLET_ID=
EXPERT_BLINK_MEMO_PREFIX=SatoShop Expert 계약 결제

# 서명 인증서: 파일 경로 방식 또는 base64 방식 중 하나 사용
EXPERT_SIGNER_CERT_PATH=
EXPERT_SIGNER_CERT_BASE64=
EXPERT_SIGNER_CERT_PASSWORD=

# 기본값이 이미 코드에 있지만 로컬에서 명시해두면 추적이 편합니다.
# EXPERT_FONT_DIR=/absolute/path/to/expert/static/expert/fonts

# DEBUG=True 이면 기본적으로 MEDIA fallback 허용
# 필요 시 명시적으로 끌 수 있습니다.
# EXPERT_SIGNATURE_MEDIA_FALLBACK=True

# -----------------------------------------------------------------------------
# S3 호환 오브젝트 스토리지
# 미설정 시 로컬 파일 저장소로 폴백합니다.
# -----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_REGION_NAME=kr-standard
S3_USE_SSL=True
S3_FILE_OVERWRITE=False
S3_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# 미디어 핫링크 보호
# -----------------------------------------------------------------------------
HOTLINK_PROTECTION_ENABLED=True
HOTLINK_ALLOWED_DOMAINS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# 메일 발송
# -----------------------------------------------------------------------------
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# -----------------------------------------------------------------------------
# 환율 업데이트 웹훅 / 외부 크론
# 앱 런타임과 외부 updater 스크립트에서 모두 사용합니다.
# -----------------------------------------------------------------------------
WEBHOOK_TOKEN=replace-with-local-webhook-token

# 외부 updater 스크립트 전용. 미설정 시 스크립트 기본 URL 목록 사용
# WEBHOOK_URLS=http://127.0.0.1:8011/webhook/update-exchange-rate/

# -----------------------------------------------------------------------------
# 실시간 / 채널 레이어 확장
# 현재 잠금 의존성에는 channels-redis가 없으므로, 실제 사용 전 의존성 추가가 필요합니다.
# -----------------------------------------------------------------------------
CHANNEL_REDIS_URL=
# REDIS_URL=

# -----------------------------------------------------------------------------
# Render / Docker 런타임 관련 참고값
# 로컬 runserver에서는 보통 필요 없고, 컨테이너 실행 시에만 의미가 있습니다.
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true
RUN_COLLECTSTATIC=true
RUN_SYSTEM_CHECK=false
PORT=8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 과거 빌드 스크립트(build.sh) 호환용 참고값
# 현재 Render Docker 런타임의 핵심 진입점은 아니지만 필요 시 남겨둡니다.
# -----------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
